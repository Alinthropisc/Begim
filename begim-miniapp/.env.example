# Telegram Bot Token (от @BotFather)
BOT_TOKEN=your_bot_token_here

# Mini App URL (Vercel или ngrok)
WEBAPP_URL=https://begim-mini-app.vercel.app

# Bot mode (development / production)
BOT_MODE=development

# --- Frontend build (Vite) ---
# Базовый URL API бэкенда с префиксом /api/v1. Префикс VITE_ обязателен.
VITE_API_URL=http://localhost:8000/api/v1
